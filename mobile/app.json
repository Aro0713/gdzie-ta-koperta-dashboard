{
  "expo": {
    "name": "Gdzie ta koperta?",
    "slug": "gdzie-ta-koperta-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gdzietakoperta",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Aplikacja używa lokalizacji, aby pokazać Twoją pozycję i wyznaczyć trasę do koperty."
        }
      ],
      [
        "expo-splash-screen",
        {
          "imageWidth": 200,
          "backgroundColor": "#ffffff",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000"
          },
          "image": "./assets/images/splash-icon.png"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3ea5f368-e658-4877-a67e-2970a134c7f6"
      }
    },
    "owner": "aro0713"
  }
}
